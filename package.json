{
  "name": "@eviano/tribunal",
  "version": "0.1.2",
  "description": "A deterministic, no-LLM-in-the-loop CI gate that catches agent-PR defects: assertion-free tests, hallucinated symbols, and PR claims that contradict the diff.",
  "type": "module",
  "bin": {
    "tribunal": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:action": "esbuild src/cli.ts --bundle --platform=node --target=node18 --format=cjs --minify --outfile=action-dist/cli.cjs",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "tsx bench/run.ts",
    "check": "tsx src/cli.ts"
  },
  "keywords": [
    "ai",
    "agents",
    "code-review",
    "ci",
    "static-analysis",
    "ast",
    "pull-request",
    "github-action"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eviano/tribunal.git"
  },
  "homepage": "https://github.com/eviano/tribunal#readme",
  "bugs": {
    "url": "https://github.com/eviano/tribunal/issues"
  },
  "dependencies": {
    "typescript": "^5.6.3"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.19.1",
    "vitest": "^2.1.2"
  }
}
